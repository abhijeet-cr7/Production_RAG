# ──────────────────────────────────────────────
# LLM Providers
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# Embedding model
# ──────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ──────────────────────────────────────────────
# Kafka
# ──────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CHUNKS=rag.chunks
KAFKA_CONSUMER_GROUP=embedding-workers

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_EMBEDDING_CACHE_TTL=86400

# ──────────────────────────────────────────────
# Vector DB (Qdrant)
# ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=production_rag
QDRANT_API_KEY=

# ──────────────────────────────────────────────
# API Gateway
# ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ──────────────────────────────────────────────
# Retrieval
# ──────────────────────────────────────────────
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ──────────────────────────────────────────────
# Chunking
# ──────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
