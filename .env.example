# ──────────────────────────────────────────────
# LLM Providers (pick one free provider)
# ──────────────────────────────────────────────
# Groq — free tier: https://console.groq.com
GROQ_API_KEY=

# Google Gemini — free tier: https://aistudio.google.com
GEMINI_API_KEY=

# Cohere — free tier: https://dashboard.cohere.com
COHERE_API_KEY=

# Mistral — free tier: https://console.mistral.ai
MISTRAL_API_KEY=

# OpenAI / Anthropic (paid)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# Embedding model
# ──────────────────────────────────────────────
# provider: sentence-transformers (local/free) | openai | cohere | gemini
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ──────────────────────────────────────────────
# Kafka
# ──────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CHUNKS=rag.chunks
KAFKA_CONSUMER_GROUP=embedding-workers

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_EMBEDDING_CACHE_TTL=86400

# ──────────────────────────────────────────────
# Vector DB (Qdrant)
# ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=production_rag
QDRANT_API_KEY=

# ──────────────────────────────────────────────
# API Gateway
# ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ──────────────────────────────────────────────
# Retrieval
# ──────────────────────────────────────────────
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ──────────────────────────────────────────────
# Chunking
# ──────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
